{
 "manifest_version": 3,
 "version": "0.0.1",
 "description": "Remove all the distractions and leave only the Video",
 "name": "FocusTube",
 "key": "",
 "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["app.js"]
    }
  ],
 "action": {
   "default_popup": "popup.html",
   "default_title": "FocusTube"
 },
 "permissions": ["activeTab"],
 "host_permissions": ["*://*.youtube.com/*"],
 "icons": {
    "16": "icons/yt_focus_icon_sm.png",
    "32": "icons/yt_focus_icon.png",
    "64": "icons/yt_focus_icon.png"
  }
}
